{
  "name": "prototypes",
  "private": true,
  "version": "1.0.0",
  "description": "Рабочая область для создания прототипов Web / Front плагинов",
  "scripts": {
    "ng": "ng",
    "dev": "ng serve --port 3000 --open",
    "start": "ng serve --port 3000 --open",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "kso:build": "powershell -ExecutionPolicy Bypass -File scripts/build-kso.ps1",
    "kso:dev": "powershell -ExecutionPolicy Bypass -File scripts/serve-kso.ps1 -dev",
    "kso:chrome": "powershell -ExecutionPolicy Bypass -File scripts/serve-kso.ps1 -chrome",
    "kso:serve": "powershell -ExecutionPolicy Bypass -File scripts/serve-kso.ps1",
    "build:all": "npm run build && npm run kso:build",
    "validate": "powershell -ExecutionPolicy Bypass -File scripts/validate.ps1",
    "lint:proto": "powershell -ExecutionPolicy Bypass -File scripts/lint-proto.ps1"
  },
  "dependencies": {
    "@angular/animations": "^16.2.0",
    "@angular/common": "^16.2.0",
    "@angular/compiler": "^16.2.0",
    "@angular/core": "^16.2.0",
    "@angular/forms": "^16.2.0",
    "@angular/platform-browser": "^16.2.0",
    "@angular/platform-browser-dynamic": "^16.2.0",
    "@angular/router": "^16.2.0",
    "lucide-angular": "^0.294.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.13.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^16.2.0",
    "@angular/cli": "^16.2.0",
    "@angular/compiler-cli": "^16.2.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.1.6"
  }
}
